# Hetzner Cloud static inventory — generated by ansible-role-hetzner-cloud
# Generated: {{ ansible_facts['date_time']['iso8601'] | default('offline') }}
# Source role variable: hcloud_provisioned_servers
# Prefer the hetzner.hcloud dynamic inventory plugin for stateless hand-off.

{% set control_plane = hcloud_provisioned_servers | default([]) | selectattr('labels', 'defined') | selectattr('labels.role', 'defined') | selectattr('labels.role', 'equalto', 'control-plane') | list %}
{% set workers = hcloud_provisioned_servers | default([]) | selectattr('labels', 'defined') | selectattr('labels.role', 'defined') | selectattr('labels.role', 'equalto', 'worker') | list %}
{% set proxy = hcloud_provisioned_servers | default([]) | selectattr('labels', 'defined') | selectattr('labels.role', 'defined') | selectattr('labels.role', 'equalto', 'proxy') | list %}
{% set ungrouped = hcloud_provisioned_servers | default([]) | rejectattr('labels', 'defined') | list %}

[control_plane]
{% for srv in control_plane %}
{{ srv.name }} ansible_host={{ srv.public_net.ipv4.ip | default('') }} hcloud_private_ip={{ (srv.private_net | default([]) | map(attribute='ip') | first) | default('') }}
{% endfor %}

[workers]
{% for srv in workers %}
{{ srv.name }} ansible_host={{ srv.public_net.ipv4.ip | default('') }} hcloud_private_ip={{ (srv.private_net | default([]) | map(attribute='ip') | first) | default('') }}
{% endfor %}

[proxy]
{% for srv in proxy %}
{{ srv.name }} ansible_host={{ srv.public_net.ipv4.ip | default('') }} hcloud_private_ip={{ (srv.private_net | default([]) | map(attribute='ip') | first) | default('') }}
{% endfor %}
{% if ungrouped | length > 0 %}

[ungrouped]
{% for srv in ungrouped %}
{{ srv.name }} ansible_host={{ srv.public_net.ipv4.ip | default('') }}
{% endfor %}
{% endif %}
